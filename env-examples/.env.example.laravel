# ============================================================
# Laravel .env — Environment Variables
# ============================================================
#
# Copy this to your Laravel project root:
#   cp .env.example.laravel /var/www/apps/yourapp/.env
#
# Then generate the app key:
#   cd /var/www/apps/yourapp
#   php artisan key:generate
#
# NEVER commit .env to version control!
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
APP_NAME="My Laravel App"
APP_ENV=production                       # local | staging | production
APP_KEY=                                 # Run: php artisan key:generate
APP_DEBUG=false                          # NEVER true in production
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
DB_CONNECTION=mysql                      # mysql | pgsql | sqlite | sqlsrv
DB_HOST=127.0.0.1
DB_PORT=3306                             # MySQL: 3306 | PostgreSQL: 5432
DB_DATABASE=myapp_db
DB_USERNAME=myapp_user
DB_PASSWORD=your_strong_password_here

# PostgreSQL (uncomment and comment out MySQL above):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=myapp_db
# DB_USERNAME=myapp_user
# DB_PASSWORD=your_strong_password_here

# ------------------------------------------------------------
# DRIVERS — Cache, Queue, Session, Broadcasting
# ------------------------------------------------------------
BROADCAST_CONNECTION=log                 # log | pusher | ably | reverb | null
FILESYSTEM_DISK=local                    # local | s3 | public

CACHE_STORE=file                         # file | redis | memcached | database | array
CACHE_PREFIX=myapp_cache_

QUEUE_CONNECTION=sync                    # sync | redis | database | sqs | beanstalkd
# QUEUE_FAILED_DRIVER=database-uuids

SESSION_DRIVER=file                      # file | redis | database | cookie | array | memcached
SESSION_LIFETIME=120                     # Minutes
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_CLIENT=phpredis                    # phpredis | predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_CHANNEL=stack                        # stack | single | daily | slack | syslog | errorlog
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                          # debug | info | notice | warning | error | critical

# Daily log rotation
# LOG_CHANNEL=daily
# LOG_DAILY_DAYS=14

# ------------------------------------------------------------
# MAIL
# ------------------------------------------------------------
MAIL_MAILER=smtp                         # smtp | sendmail | mailgun | ses | postmark | log | array
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password          # Use App Password for Gmail
MAIL_ENCRYPTION=tls                      # tls | ssl | null
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SECRET=your-mailgun-key
# MAILGUN_ENDPOINT=api.mailgun.net

# Amazon SES
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ------------------------------------------------------------
# HASHING
# ------------------------------------------------------------
BCRYPT_ROUNDS=12                         # Default 12, higher = slower but more secure

# ------------------------------------------------------------
# FILE STORAGE — AWS S3 / DigitalOcean Spaces
# ------------------------------------------------------------
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
# AWS_URL=                               # Custom CDN URL (optional)
# AWS_USE_PATH_STYLE_ENDPOINT=false

# DigitalOcean Spaces (S3-compatible)
# AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_URL=https://your-space.nyc3.cdn.digitaloceanspaces.com

# ------------------------------------------------------------
# PUSHER / BROADCASTING (Real-time)
# ------------------------------------------------------------
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=your_app_id
# PUSHER_APP_KEY=your_app_key
# PUSHER_APP_SECRET=your_app_secret
# PUSHER_APP_CLUSTER=mt1
# PUSHER_SCHEME=https
# PUSHER_PORT=443

# Laravel Reverb (self-hosted WebSocket)
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=your_app_id
# REVERB_APP_KEY=your_app_key
# REVERB_APP_SECRET=your_app_secret
# REVERB_HOST=localhost
# REVERB_PORT=8080

# Vite (for frontend broadcasting)
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ------------------------------------------------------------
# AUTHENTICATION — Social Login (Laravel Socialite)
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/google/callback

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URL=https://yourdomain.com/auth/github/callback

# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URL=https://yourdomain.com/auth/facebook/callback

# ------------------------------------------------------------
# PAYMENTS — Stripe / PayPal
# ------------------------------------------------------------
# STRIPE_KEY=pk_live_xxxxx                # Publishable key (safe for frontend)
# STRIPE_SECRET=sk_live_xxxxx             # Secret key (server only!)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# CASHIER_CURRENCY=usd

# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live                        # sandbox | live

# ------------------------------------------------------------
# SEARCH — Scout / Algolia / Meilisearch
# ------------------------------------------------------------
# SCOUT_DRIVER=meilisearch                # algolia | meilisearch | database | collection
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_KEY=your_master_key

# ALGOLIA_APP_ID=
# ALGOLIA_SECRET=

# ------------------------------------------------------------
# MONITORING — Sentry / Telescope
# ------------------------------------------------------------
# SENTRY_LARAVEL_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_TRACES_SAMPLE_RATE=0.1           # 10% of requests

# TELESCOPE_ENABLED=false                 # Disable in production

# ------------------------------------------------------------
# SANCTUM / API
# ------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,localhost:3000
# SESSION_DOMAIN=.yourdomain.com          # For subdomain sharing

# ------------------------------------------------------------
# VITE (Frontend Build Variables)
# Prefix with VITE_ to expose to frontend
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
