# ============================================================
# Node.js .env — Environment Variables (Express / Fastify / Koa)
# ============================================================
#
# Copy this to your Node.js project root:
#   cp .env.example.nodejs /var/www/apps/yourapp/.env
#
# Load in your code:
#   require('dotenv').config()     // CommonJS
#   import 'dotenv/config'         // ESM
#
# Install dotenv:
#   npm install dotenv
#
# NEVER commit .env to version control!
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NODE_ENV=production                      # development | staging | production
PORT=3000
HOST=0.0.0.0                            # Bind to all interfaces on VPS

APP_NAME="My Node.js App"
APP_URL=https://yourdomain.com

# Secret key for JWT / session signing (min 32 characters)
APP_SECRET=your_random_secret_key_here_change_this_in_production

# ------------------------------------------------------------
# DATABASE — MySQL
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=your_strong_password_here

# Connection string format (MySQL):
DATABASE_URL=mysql://myapp_user:your_strong_password_here@127.0.0.1:3306/myapp_db

# ------------------------------------------------------------
# DATABASE — PostgreSQL (uncomment if using PostgreSQL)
# ------------------------------------------------------------
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=myapp_db
# DB_USER=myapp_user
# DB_PASSWORD=your_strong_password_here

# Connection string format (PostgreSQL):
# DATABASE_URL=postgresql://myapp_user:your_strong_password_here@127.0.0.1:5432/myapp_db

# Prisma-specific (append connection pool settings):
# DATABASE_URL=postgresql://myapp_user:password@127.0.0.1:5432/myapp_db?connection_limit=5

# ------------------------------------------------------------
# DATABASE — MongoDB (uncomment if using MongoDB)
# ------------------------------------------------------------
# MONGODB_URI=mongodb://127.0.0.1:27017/myapp_db
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/myapp_db

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=7d                        # 1h | 7d | 30d
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------
# SESSION (if using express-session)
# ------------------------------------------------------------
# SESSION_SECRET=your_session_secret_key
# SESSION_MAX_AGE=86400000               # 24 hours in milliseconds
# SESSION_NAME=myapp.sid

# ------------------------------------------------------------
# MAIL / SMTP
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                        # true for 465, false for 587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="My App <noreply@yourdomain.com>"

# SendGrid
# SENDGRID_API_KEY=SG.xxxxx

# Mailgun
# MAILGUN_API_KEY=your-mailgun-key
# MAILGUN_DOMAIN=mg.yourdomain.com

# ------------------------------------------------------------
# FILE UPLOADS
# ------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760                   # 10MB in bytes

# AWS S3 / DigitalOcean Spaces
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
# AWS_ENDPOINT=                          # For DigitalOcean Spaces

# Cloudinary
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
CORS_ORIGIN=https://yourdomain.com       # Comma-separated for multiple
# CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000              # 15 minutes
RATE_LIMIT_MAX=100                       # Max requests per window

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=error                          # debug | info | warn | error
# LOG_FILE=./logs/app.log

# ------------------------------------------------------------
# PAYMENTS
# ------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# PayPal
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live                       # sandbox | live

# ------------------------------------------------------------
# SOCIAL AUTH (Passport.js / OAuth)
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback

# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_CALLBACK_URL=https://yourdomain.com/auth/facebook/callback

# ------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ------------------------------------------------------------
# QUEUE / BACKGROUND JOBS (BullMQ)
# ------------------------------------------------------------
# QUEUE_REDIS_URL=redis://127.0.0.1:6379
# QUEUE_CONCURRENCY=5
