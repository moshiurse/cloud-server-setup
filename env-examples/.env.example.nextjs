# ============================================================
# Next.js .env — Environment Variables
# ============================================================
#
# Copy this to your Next.js project root:
#   cp .env.example.nextjs /var/www/apps/yourapp/.env.local
#
# Next.js env file priority (highest to lowest):
#   .env.local            ← Your local overrides (gitignored)
#   .env.production       ← Production defaults
#   .env.development      ← Development defaults
#   .env                  ← Base defaults
#
# IMPORTANT — Two types of variables:
#   NEXT_PUBLIC_*  → Exposed to browser (bundled into client JS)
#   Everything else → Server-only (API routes, SSR, middleware)
#
# NEVER put secrets in NEXT_PUBLIC_ variables!
#
# NEVER commit .env.local to version control!
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NODE_ENV=production                      # development | production
PORT=3000
HOSTNAME=0.0.0.0                         # Bind to all interfaces on VPS

# Site URL (used for absolute URLs in SSR, metadata, OG images)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# API base URL
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
# Or external API:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ------------------------------------------------------------
# DATABASE (Server-only — used in API routes / Server Components)
# ------------------------------------------------------------
DATABASE_URL=mysql://myapp_user:your_password@127.0.0.1:3306/myapp_db

# PostgreSQL:
# DATABASE_URL=postgresql://myapp_user:your_password@127.0.0.1:5432/myapp_db

# Prisma connection pool:
# DATABASE_URL=postgresql://myapp_user:password@127.0.0.1:5432/myapp_db?connection_limit=5

# MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/myapp_db

# Redis:
# REDIS_URL=redis://127.0.0.1:6379

# ------------------------------------------------------------
# AUTHENTICATION — NextAuth.js / Auth.js
# ------------------------------------------------------------
# Required for NextAuth.js:
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars_run_openssl_rand_base64_32

# Generate NEXTAUTH_SECRET:
#   openssl rand -base64 32

# Google OAuth
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# GitHub OAuth
# GITHUB_ID=your_github_oauth_app_id
# GITHUB_SECRET=your_github_oauth_secret

# Discord OAuth
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Credentials provider (email/password)
# No extra env vars needed — implement in [...nextauth].ts

# ------------------------------------------------------------
# AUTHENTICATION — Clerk (Alternative)
# ------------------------------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
# CLERK_SECRET_KEY=sk_live_xxxxx
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ------------------------------------------------------------
# MAIL / EMAIL (Server-only)
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# MAIL_FROM=noreply@yourdomain.com

# Resend (popular with Next.js):
# RESEND_API_KEY=re_xxxxx

# SendGrid:
# SENDGRID_API_KEY=SG.xxxxx

# ------------------------------------------------------------
# FILE STORAGE (Server-only)
# ------------------------------------------------------------
# AWS S3 / Vercel Blob
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket-name

# Uploadthing (popular with Next.js):
# UPLOADTHING_SECRET=sk_live_xxxxx
# UPLOADTHING_APP_ID=xxxxx

# Cloudinary:
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ------------------------------------------------------------
# PAYMENTS
# ------------------------------------------------------------
# Stripe (server-side)
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe (client-side — safe to expose)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# LemonSqueezy:
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=

# ------------------------------------------------------------
# CMS / CONTENT (if using headless CMS)
# ------------------------------------------------------------
# Sanity
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=

# Contentful
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# CONTENTFUL_PREVIEW_TOKEN=

# Strapi
# NEXT_PUBLIC_STRAPI_URL=https://cms.yourdomain.com
# STRAPI_API_TOKEN=

# ------------------------------------------------------------
# ANALYTICS & MONITORING (Client-side — safe to expose)
# ------------------------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Vercel Analytics (auto if deployed on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (server-side)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=                     # For source maps upload
# NEXT_PUBLIC_SENTRY_DSN=               # Client-side error tracking

# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_FEATURE_X=true
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# ------------------------------------------------------------
# OPEN AI / AI FEATURES
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_ORG_ID=org-xxxxx

# ------------------------------------------------------------
# RATE LIMITING / SECURITY (Server-only)
# ------------------------------------------------------------
# RATE_LIMIT_MAX=100                     # Max requests per window
# RATE_LIMIT_WINDOW=900                  # Window in seconds (15 min)

# CSP Nonce (auto-generated in middleware usually)
# NEXT_PUBLIC_CSP_NONCE=
