# ============================================================
# React.js .env — Environment Variables (CRA / Vite)
# ============================================================
#
# Copy this to your React project root:
#   cp .env.example.reactjs /var/www/apps/yourapp/.env
#
# ⚠️  IMPORTANT — ALL variables are bundled into the build!
#   React is a frontend app — there is no server-side.
#   Every variable in .env is embedded in the JavaScript bundle.
#   NEVER put secrets (API keys, DB passwords) here!
#
# Variable prefix rules:
#   Create React App (CRA):  REACT_APP_*
#   Vite:                     VITE_*
#
# After changing .env, you MUST rebuild:
#   npm run build
#
# NEVER commit .env to version control!
# ============================================================


# ████████████████████████████████████████████████████████████
# CREATE REACT APP (CRA) — All variables must start with REACT_APP_
# ████████████████████████████████████████████████████████████

# ------------------------------------------------------------
# API & BACKEND
# ------------------------------------------------------------
REACT_APP_API_URL=https://api.yourdomain.com
# REACT_APP_API_URL=http://localhost:4000                    # Development
REACT_APP_SITE_URL=https://yourdomain.com

# WebSocket (if applicable)
# REACT_APP_WS_URL=wss://api.yourdomain.com
# REACT_APP_WS_URL=ws://localhost:4000                      # Development

# ------------------------------------------------------------
# APP SETTINGS
# ------------------------------------------------------------
REACT_APP_NAME="My React App"
REACT_APP_VERSION=$npm_package_version
# REACT_APP_DEFAULT_LANGUAGE=en
# REACT_APP_ITEMS_PER_PAGE=20

# ------------------------------------------------------------
# AUTHENTICATION
# ------------------------------------------------------------
# Auth0
# REACT_APP_AUTH0_DOMAIN=yourapp.auth0.com
# REACT_APP_AUTH0_CLIENT_ID=xxxxx
# REACT_APP_AUTH0_AUDIENCE=https://api.yourdomain.com
# REACT_APP_AUTH0_REDIRECT_URI=https://yourdomain.com/callback

# Firebase Auth
# REACT_APP_FIREBASE_API_KEY=AIzaxxxxx
# REACT_APP_FIREBASE_AUTH_DOMAIN=yourapp.firebaseapp.com
# REACT_APP_FIREBASE_PROJECT_ID=yourapp
# REACT_APP_FIREBASE_STORAGE_BUCKET=yourapp.appspot.com
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
# REACT_APP_FIREBASE_APP_ID=1:123456789:web:xxxxx

# Clerk
# REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx

# ------------------------------------------------------------
# PAYMENTS (Publishable keys ONLY — never secret keys!)
# ------------------------------------------------------------
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# REACT_APP_PAYPAL_CLIENT_ID=

# ------------------------------------------------------------
# ANALYTICS & TRACKING
# ------------------------------------------------------------
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX
# REACT_APP_GTM_ID=GTM-XXXXXXX
# REACT_APP_MIXPANEL_TOKEN=
# REACT_APP_HOTJAR_ID=

# Sentry (client-side error tracking)
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ------------------------------------------------------------
# MAPS
# ------------------------------------------------------------
# REACT_APP_GOOGLE_MAPS_API_KEY=AIzaxxxxx
# REACT_APP_MAPBOX_TOKEN=pk.xxxxx

# ------------------------------------------------------------
# MEDIA / CDN
# ------------------------------------------------------------
# REACT_APP_CDN_URL=https://cdn.yourdomain.com
# REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
# REACT_APP_IMAGE_BASE_URL=https://images.yourdomain.com

# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# REACT_APP_ENABLE_DARK_MODE=true
# REACT_APP_ENABLE_NOTIFICATIONS=true
# REACT_APP_MAINTENANCE_MODE=false


# ████████████████████████████████████████████████████████████
# VITE — All variables must start with VITE_
# ████████████████████████████████████████████████████████████
#
# If using Vite instead of CRA, use VITE_ prefix:
# (Comment out the REACT_APP_ section above and use these)

# ------------------------------------------------------------
# API & BACKEND
# ------------------------------------------------------------
# VITE_API_URL=https://api.yourdomain.com
# VITE_SITE_URL=https://yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com

# ------------------------------------------------------------
# APP SETTINGS
# ------------------------------------------------------------
# VITE_APP_NAME="My React App"
# VITE_APP_VERSION=$npm_package_version

# ------------------------------------------------------------
# AUTHENTICATION
# ------------------------------------------------------------
# VITE_AUTH0_DOMAIN=yourapp.auth0.com
# VITE_AUTH0_CLIENT_ID=xxxxx

# VITE_FIREBASE_API_KEY=AIzaxxxxx
# VITE_FIREBASE_AUTH_DOMAIN=yourapp.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=yourapp

# VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx

# ------------------------------------------------------------
# PAYMENTS
# ------------------------------------------------------------
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ------------------------------------------------------------
# ANALYTICS
# ------------------------------------------------------------
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# VITE_ENABLE_DARK_MODE=true
# VITE_MAINTENANCE_MODE=false
